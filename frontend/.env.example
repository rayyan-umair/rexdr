# API base path - Nginx gateway routes /api/* to the right engine
VITE_API_BASE=/api

# WebSocket base path - Nginx gateway routes /ws-api/* with Upgrade headers
VITE_WS_BASE=

# Set to "true" once an AI provider is configured in the launcher
VITE_AI_CONFIGURED=false