# =============================================================================
# REXDR - Environment Configuration
# .env.example - Copy this to .env and fill in your values
#
# Author  : Rayyan Umair
# Date    : 2026-06-12
# =============================================================================

# -----------------------------------------------------------------------------
# Windows / Active Directory credentials
# -----------------------------------------------------------------------------
WINRM_USERNAME=administrator
WINRM_PASSWORD=your_password_here
LDAP_BASE_DN=DC=corp,DC=local
LDAP_DOMAIN=corp.local

# -----------------------------------------------------------------------------
# Network capture
# -----------------------------------------------------------------------------
CAPTURE_INTERFACE=eth0

# -----------------------------------------------------------------------------
# AI integration - leave blank to disable AI features
# Supported: groq, openai, anthropic, gemini, ollama
# Groq is recommended - free and fast
# -----------------------------------------------------------------------------
AI_PROVIDER=groq
AI_API_KEY=your_api_key_here
AI_MODEL=
AI_BASE_URL=

# -----------------------------------------------------------------------------
# Vulnerability intelligence
# Get a free NVD API key at https://nvd.nist.gov/developers/request-an-api-key
# -----------------------------------------------------------------------------
NVD_API_KEY=

# -----------------------------------------------------------------------------
# Platform settings
# -----------------------------------------------------------------------------
DB_RETENTION_DAYS=30
SCAN_INTERVAL_MINUTES=60
CVE_SYNC_INTERVAL_HOURS=24